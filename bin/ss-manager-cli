main_menu() {
    while true; do
        print_banner
        print_status_line
        echo ""
        echo -e "  ${BOLD}═══ 服务控制 ═══${NC}"
        echo -e "  ${GREEN}1${NC}) 启动服务          ${GREEN}2${NC}) 停止服务"
        echo -e "  ${GREEN}3${NC}) 重启服务          ${GREEN}4${NC}) 查看状态"
        echo ""
        echo -e "  ${BOLD}═══ 配置管理 ═══${NC}"
        echo -e "  ${GREEN}5${NC}) 修改端口          ${GREEN}6${NC}) 修改密码"
        echo -e "  ${GREEN}7${NC}) 修改加密方式      ${GREEN}8${NC}) 监听所有接口"
        echo ""
        echo -e "  ${BOLD}═══ 连接信息 ═══${NC}"
        echo -e "  ${GREEN}9${NC}) 显示连接 URI      ${GREEN}10${NC}) 生成二维码"
        echo ""
        echo -e "  ${BOLD}═══ 多用户管理 ═══${NC}"
        echo -e "  ${GREEN}11${NC}) 用户列表          ${GREEN}12${NC}) 添加用户"
        echo -e "  ${GREEN}13${NC}) 删除用户          ${GREEN}14${NC}) 启动用户实例"
        echo -e "  ${GREEN}15${NC}) 停止用户实例"
        echo ""
        echo -e "  ${BOLD}═══ 工具 ═══${NC}"
        echo -e "  ${GREEN}16${NC}) 快捷初始化        ${GREEN}17${NC}) 查看日志"
        echo -e "  ${GREEN}18${NC}) 防火墙管理        ${GREEN}19${NC}) 网络诊断"
        echo -e "  ${GREEN}20${NC}) 配置备份列表      ${GREEN}21${NC}) ${RED}一键修复代理${NC}"
        echo ""
        echo -e "  ${BOLD}${CYAN}═══ TG 代理 (MTProto) ═══${NC}"
        echo -e "  ${GREEN}22${NC}) ${CYAN}TG 代理管理面板${NC}"
        echo ""
        echo -e "  ${BOLD}${MAGENTA}═══ Web 管理器 ═══${NC}"
        echo -e "  ${GREEN}23${NC}) ${MAGENTA}Web 管理面板${NC}"
        echo -e "  ${GREEN}24${NC}) ${MAGENTA}⚡ 下载加速器${NC}"
        echo -e "  ${GREEN}25${NC}) ${MAGENTA}🔗 GitHub 仓库加速${NC}"
        echo ""
        echo -e "  ${RED}0${NC}) 退出"
        echo ""
        echo -ne "  ${CYAN}请选择 [0-25]: ${NC}"
        read -r choice

        case "$choice" in
            1) start_server;;
            2) stop_server;;
            3) restart_server;;
            4) show_status;;
            5) change_port;;
            6) change_password;;
            7) change_method;;
            8) change_listen_all;;
            9) show_uri;;
            10) show_qr;;
            11) list_users;;
            12) add_user;;
            13) remove_user;;
            14) start_user;;
            15) stop_user;;
            16) quick_setup;;
            17) show_logs;;
            18) firewall_menu;;
            19) speed_test;;
            20)
                echo -e "\n${BOLD}══════════ 配置备份 ══════════${NC}"
                ls -la "$BACKUP_DIR" 2>/dev/null || echo -e "${YELLOW}无备份${NC}";;
            21) fix_proxy;;
            22) tg_menu;;
            23) web_menu;;
            24) show_dl_info;;
            25) show_gh_info;;
            0)
                echo -e "\n${GREEN}再见!${NC}\n"; exit 0;;
            *) echo -e "${RED}无效选择, 请重试${NC}";;
        esac
        echo ""
        echo -ne "${YELLOW}按 Enter 返回菜单...${NC}"
        read -r
    done
}

#=============================================================================
# 快速命令支持
#=============================================================================
case "${1:-}" in
    start)   start_server; exit;;
    stop)    stop_server; exit;;
    restart) restart_server; exit;;
    status)  show_status; exit;;
    uri)     show_uri; exit;;
    qr)      show_qr; exit;;
    log)     show_logs "${2:-30}"; exit;;
    quick)   quick_setup; exit;;
    users)   list_users; exit;;
    fix)     fix_proxy; exit;;
    tg)      tg_menu; exit;;
    tg-start)   tg_start; exit;;
    tg-stop)    tg_stop; exit;;
    tg-restart) tg_restart; exit;;
    tg-status)  tg_status; exit;;
    tg-link)    tg_link; exit;;
    tg-qr)      tg_qr; exit;;
    tg-init)    tg_init; exit;;
    tg-fix)     tg_fix_all; exit;;
    web)        web_menu; exit;;
    web-start)  web_start; exit;;
    web-stop)   web_stop; exit;;
    web-status) web_status; exit;;
    dl)         show_dl_info; exit;;
    gh)         show_gh_info; exit;;
    *)       main_menu;;
esac