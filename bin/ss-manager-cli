#!/bin/bash
#=============================================================================
#  Shadowrocket 节点管理脚本 (Shadowsocks-libev)
#  支持: 启动/停止/状态/修改配置/查看连接/生成 QR 码/多用户
#  用法: ss-manager-cli [start|stop|restart|status|uri|qr|log|quick|users]
#=============================================================================

set -eo pipefail

CONFIG_FILE="/root/ss-config.json"
CONFIG_DIR="/root/ss-configs"
SERVICE_NAME="shadowsocks-libev"
PID_FILE="/tmp/ss-server.pid"
BACKUP_DIR="$CONFIG_DIR/backups"
USERS_DIR="$CONFIG_DIR/users"
SERVER_IP=$(curl -s --connect-timeout 3 ifconfig.me 2>/dev/null || curl -s --connect-timeout 3 ip.sb 2>/dev/null || echo "未知")

# TG 代理配置
TG_BIN="/root/mtproto/mtproto-proxy"
TG_DIR="/root/mtproto"
TG_CONF="/root/mtproto/proxy-multi.conf"
TG_SECRET_FILE="/root/mtproto/proxy-secret"
TG_PID="/tmp/mtproto-proxy.pid"
TG_PORT_FILE="/root/mtproto/tg-port.conf"
TG_SECRET_FILE_USER="/root/mtproto/tg-secret.conf"

# 颜色
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

#=============================================================================
# 工具函数
#=============================================================================
print_banner() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "  ╔══════════════════════════════════════════════╗"
    echo "  ║        Shadowrocket 节点管理面板            ║"
    echo "  ║        Shadowsocks-libev Server             ║"
    echo "  ╚══════════════════════════════════════════════╝"
    echo -e "${NC}"
}

is_running() {
    [ -f "$PID_FILE" ] && kill -0 $(cat "$PID_FILE") 2>/dev/null
}

print_status_line() {
    local status
    if is_running; then
        status="${GREEN}● 运行中${NC} (PID: $(cat "$PID_FILE"))"
    else
        status="${RED}● 已停止${NC}"
    fi
    echo -e "  服务状态: ${status}    服务器IP: ${YELLOW}${SERVER_IP}${NC}"
    echo -e "  ─────────────────────────────────────────────"
}

backup_config() {
    mkdir -p "$BACKUP_DIR"
    cp "$CONFIG_FILE" "$BACKUP_DIR/config_$(date +%Y%m%d_%H%M%S).json"
}

get_port()     { jq -r '.server_port' "$CONFIG_FILE"; }
get_password() { jq -r '.password' "$CONFIG_FILE"; }
get_method()   { jq -r '.method' "$CONFIG_FILE"; }
get_server() { 
    local s=$(jq -r '.server' "$CONFIG_FILE")
    if [[ "$s" == "null" ]]; then
        echo "0.0.0.0"
    elif [[ "$s" == "["* ]]; then
        jq -r '.server | join(", ")' "$CONFIG_FILE"
    else
        echo "$s"
    fi
}

#=============================================================================
# 核心功能
#=============================================================================

start_server() {
    if is_running; then
        echo -e "${YELLOW}服务已在运行中 (PID: $(cat "$PID_FILE"))${NC}"
        return
    fi
    echo -e "\n${YELLOW}正在启动服务...${NC}"
    mkdir -p "$(dirname "$PID_FILE")"
    
    if [ ! -f "/usr/bin/ss-server" ]; then
        echo -e "${RED}✗ ss-server 未安装，请运行: apt-get install shadowsocks-libev${NC}"
        return
    fi
    
    if [ ! -f "$CONFIG_FILE" ]; then
        echo -e "${RED}✗ 配置文件不存在: $CONFIG_FILE${NC}"
        return
    fi
    
    local test_out=$(ss-server -c "$CONFIG_FILE" -t 2>&1 | head -5)
    if [ $? -ne 0 ] && echo "$test_out" | grep -q -E "(error|Error|ERROR|invalid|Invalid)"; then
        echo -e "${RED}✗ 配置文件无效:${NC}"
        echo "$test_out"
        return
    fi
    
    nohup ss-server -c "$CONFIG_FILE" -f "$PID_FILE" > /tmp/ss-server.log 2>&1 &
    sleep 2
    if is_running; then
        echo -e "${GREEN}✓ 服务启动成功 (PID: $(cat "$PID_FILE"))${NC}"
    else
        echo -e "${RED}✗ 启动失败, 日志:${NC}"
        if [ -f "/tmp/ss-server.log" ]; then
            tail -20 /tmp/ss-server.log
        else
            echo "日志文件不存在"
        fi
        echo ""
        echo -e "${YELLOW}诊断信息:${NC}"
        echo "  配置文件: $CONFIG_FILE"
        echo "  PID文件: $PID_FILE"
        echo "  ss-server路径: $(which ss-server 2>/dev/null || echo "未找到")"
        echo "  端口占用: $(netstat -tlnp 2>/dev/null | grep $(get_port) || echo "未占用")"
    fi
}

stop_server() {
    if ! is_running; then
        echo -e "${YELLOW}服务未在运行${NC}"
        return
    fi
    local pid=$(cat "$PID_FILE")
    echo -e "\n${YELLOW}正在停止服务 (PID: ${pid})...${NC}"
    kill "$pid" 2>/dev/null
    sleep 1
    if is_running; then
        kill -9 "$pid" 2>/dev/null
        sleep 1
    fi
    rm -f "$PID_FILE"
    echo -e "${GREEN}✓ 服务已停止${NC}"
}

restart_server() {
    echo -e "\n${YELLOW}正在重启服务...${NC}"
    stop_server 2>/dev/null
    sleep 1
    start_server
}

show_status() {
    echo -e "\n${BOLD}══════════ 服务详情 ══════════${NC}"
    echo -e "${CYAN}服务器地址:${NC} ${YELLOW}${SERVER_IP}${NC}"
    echo -e "${CYAN}监听端口:  ${NC} ${GREEN}$(get_port)${NC}"
    echo -e "${CYAN}加密方式:  ${NC} ${GREEN}$(get_method)${NC}"
    echo -e "${CYAN}连接密码:  ${NC} ${GREEN}$(get_password)${NC}"
    echo -e "${CYAN}监听地址:  ${NC} $(get_server)"
    echo ""

    if is_running; then
        local pid=$(cat "$PID_FILE")
        echo -e "${BOLD}══════════ 运行状态 ══════════${NC}"
        echo -e "${CYAN}进程 PID:${NC}  ${GREEN}${pid}${NC}"
        echo -e "${CYAN}运行时间:${NC}  ${GREEN}$(ps -o etime= -p "$pid" 2>/dev/null || echo "未知")${NC}"
        echo -e "${CYAN}内存占用:${NC}  ${GREEN}$(ps -o rss= -p "$pid" 2>/dev/null | awk '{printf "%.1f MB", $1/1024}' || echo "未知")${NC}"
    else
        echo -e "${BOLD}══════════ 运行状态 ══════════${NC}"
        echo -e "${RED}服务未运行${NC}"
    fi

    echo -e "\n${BOLD}══════════ 连接统计 ══════════${NC}"
    local port=$(get_port)
    local count=$(ss -tuln 2>/dev/null | grep -c ":${port} " || echo 0)
    echo -e "${CYAN}端口监听:${NC} ${GREEN}${count}${NC} 个监听"
    local conns=$(ss -tn state established "( sport = :${port} or dport = :${port} )" 2>/dev/null | wc -l)
    echo -e "${CYAN}活跃连接:${NC} ${GREEN}$((conns > 0 ? conns - 1 : 0))${NC} 个"
}

show_uri() {
    local method=$(get_method)
    local password=$(get_password)
    local port=$(get_port)
    local encoded=$(echo -n "${method}:${password}" | base64 -w 0)
    local uri="ss://${encoded}@${SERVER_IP}:${port}"

    echo -e "\n${BOLD}══════════ Shadowrocket 连接信息 ══════════${NC}\n"
    echo -e "${CYAN}SS 链接:${NC}"
    echo -e "${GREEN}${uri}${NC}"
    echo ""
    echo -e "${CYAN}手动配置:${NC}"
    echo -e "  服务器: ${GREEN}${SERVER_IP}${NC}"
    echo -e "  端口:   ${GREEN}$(get_port)${NC}"
    echo -e "  密码:   ${GREEN}$(get_password)${NC}"
    echo -e "  加密:   ${GREEN}$(get_method)${NC}"
    echo ""
    echo -e "${YELLOW}提示: 在 Shadowrocket 中扫描二维码或手动添加以上信息${NC}"
}

show_qr() {
    local method=$(get_method)
    local password=$(get_password)
    local port=$(get_port)
    local encoded=$(echo -n "${method}:${password}" | base64 -w 0)
    local uri="ss://${encoded}@${SERVER_IP}:${port}"

    echo -e "\n${BOLD}══════════ 扫描二维码添加节点 ══════════${NC}\n"
    if command -v qrencode &>/dev/null; then
        qrencode -t ANSIUTF8 -m 1 -s 2 "$uri" 2>/dev/null || {
            echo -e "${YELLOW}终端不支持 UTF8 二维码, 生成 PNG 中...${NC}"
            qrencode -o /tmp/ss_qr.png -s 8 "$uri" 2>/dev/null
            echo -e "${GREEN}二维码已保存到: /tmp/ss_qr.png${NC}"
        }
    else
        echo -e "${RED}qrencode 未安装${NC}"
    fi
    echo ""
    echo -e "${YELLOW}提示: 打开 Shadowrocket → 右上角 + → 扫描二维码${NC}"
}

show_logs() {
    local lines=${1:-30}
    echo -e "\n${BOLD}══════════ 最近 ${lines} 行日志 ══════════${NC}\n"
    if [ -f /tmp/ss-server.log ]; then
        tail -n "$lines" /tmp/ss-server.log
    else
        echo -e "${YELLOW}无日志记录${NC}"
    fi
}

#=============================================================================
# 配置修改
#=============================================================================

change_port() {
    echo -ne "${CYAN}输入新端口 (1024-65535): ${NC}"
    read -r new_port
    if [[ "$new_port" =~ ^[0-9]+$ ]] && [ "$new_port" -ge 1024 ] && [ "$new_port" -le 65535 ]; then
        backup_config
        jq --arg p "$new_port" '.server_port = ($p | tonumber)' "$CONFIG_FILE" > /tmp/ss_config.json && mv /tmp/ss_config.json "$CONFIG_FILE"
        echo -e "${GREEN}✓ 端口已修改为 ${new_port}${NC}"
        echo -e "${YELLOW}需要重启服务生效${NC}"
    else
        echo -e "${RED}✗ 无效端口号${NC}"
    fi
}

change_password() {
    echo -ne "${CYAN}输入新密码: ${NC}"
    read -r new_pass
    if [ -n "$new_pass" ]; then
        backup_config
        jq --arg p "$new_pass" '.password = $p' "$CONFIG_FILE" > /tmp/ss_config.json && mv /tmp/ss_config.json "$CONFIG_FILE"
        echo -e "${GREEN}✓ 密码已修改${NC}"
        echo -e "${YELLOW}需要重启服务生效${NC}"
    else
        echo -e "${RED}✗ 密码不能为空${NC}"
    fi
}

change_method() {
    echo -e "\n${CYAN}可选加密方式:${NC}"
    echo "  1) aes-256-gcm           (推荐)"
    echo "  2) aes-128-gcm"
    echo "  3) chacha20-ietf-poly1305 (推荐)"
    echo "  4) xchacha20-ietf-poly1305"
    echo "  5) aes-256-cfb"
    echo "  6) aes-128-cfb"
    echo "  7) chacha20"
    echo "  8) chacha20-ietf"
    echo -ne "${CYAN}选择 [1-8]: ${NC}"
    read -r choice
    local method
    case "$choice" in
        1) method="aes-256-gcm";;
        2) method="aes-128-gcm";;
        3) method="chacha20-ietf-poly1305";;
        4) method="xchacha20-ietf-poly1305";;
        5) method="aes-256-cfb";;
        6) method="aes-128-cfb";;
        7) method="chacha20";;
        8) method="chacha20-ietf";;
        *) echo -e "${RED}✗ 无效选择${NC}"; return;;
    esac
    backup_config
    jq --arg m "$method" '.method = $m' "$CONFIG_FILE" > /tmp/ss_config.json && mv /tmp/ss_config.json "$CONFIG_FILE"
    echo -e "${GREEN}✓ 加密方式已修改为 ${method}${NC}"
    echo -e "${YELLOW}需要重启服务生效${NC}"
}

change_listen_all() {
    backup_config
    jq '.server = ["0.0.0.0", "::"]' "$CONFIG_FILE" > /tmp/ss_config.json && mv /tmp/ss_config.json "$CONFIG_FILE"
    echo -e "${GREEN}✓ 已设置为监听所有网络接口${NC}"
    echo -e "${YELLOW}需要重启服务生效${NC}"
}

#=============================================================================
# 多用户管理
#=============================================================================

list_users() {
    mkdir -p "$USERS_DIR"
    echo -e "\n${BOLD}══════════ 多用户配置列表 ══════════${NC}\n"
    local found=0
    for f in "$USERS_DIR"/*.json; do
        [ -f "$f" ] || continue
        found=1
        local name=$(basename "$f" .json)
        local port=$(jq -r '.server_port' "$f")
        local method=$(jq -r '.method' "$f")
        local pass=$(jq -r '.password' "$f")
        echo -e "${CYAN}用户:${NC} ${GREEN}${name}${NC}  ${CYAN}端口:${NC} ${port}  ${CYAN}加密:${NC} ${method}  ${CYAN}密码:${NC} ${pass}"
    done
    if [ "$found" -eq 0 ]; then
        echo -e "${YELLOW}暂无额外用户配置${NC}"
    fi
    echo -e "\n${CYAN}主配置 (端口 $(get_port)):${NC} 密码 ${GREEN}$(get_password)${NC}"
}

add_user() {
    echo -ne "${CYAN}输入用户名: ${NC}"; read -r username
    [ -z "$username" ] && { echo -e "${RED}用户名不能为空${NC}"; return; }
    echo -ne "${CYAN}输入端口号: ${NC}"; read -r port
    [[ "$port" =~ ^[0-9]+$ ]] && [ "$port" -ge 1024 ] && [ "$port" -le 65535 ] || { echo -e "${RED}无效端口${NC}"; return; }
    echo -ne "${CYAN}输入密码 (留空自动生成): ${NC}"; read -r password
    [ -z "$password" ] && password=$(tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 16)
    echo -ne "${CYAN}加密方式 [默认: aes-256-gcm]: ${NC}"; read -r method
    [ -z "$method" ] && method="aes-256-gcm"

    mkdir -p "$USERS_DIR"
    cat > "$USERS_DIR/${username}.json" << EOF
{
    "server": ["0.0.0.0", "::"],
    "mode": "tcp_and_udp",
    "server_port": ${port},
    "password": "${password}",
    "timeout": 86400,
    "method": "${method}",
    "fast_open": true
}
EOF
    echo -e "${GREEN}✓ 用户 ${username} 已创建${NC}"
    echo -e "${CYAN}  端口: ${port}  密码: ${password}  加密: ${method}${NC}"
    echo -e "${YELLOW}启动方式: ss-server -c ${USERS_DIR}/${username}.json${NC}"
}

remove_user() {
    list_users
    echo -ne "${CYAN}输入要删除的用户名: ${NC}"; read -r username
    if [ -f "$USERS_DIR/${username}.json" ]; then
        rm -f "$USERS_DIR/${username}.json"
        echo -e "${GREEN}✓ 用户 ${username} 已删除${NC}"
    else
        echo -e "${RED}✗ 用户不存在${NC}"
    fi
}

start_user() {
    echo -ne "${CYAN}输入要启动的用户名: ${NC}"; read -r username
    if [ ! -f "$USERS_DIR/${username}.json" ]; then
        echo -e "${RED}✗ 用户 ${username} 不存在${NC}"; return
    fi
    local port=$(jq -r '.server_port' "$USERS_DIR/${username}.json")
    if ss -tuln 2>/dev/null | grep -q ":${port} "; then
        echo -e "${RED}✗ 端口 ${port} 已被占用${NC}"; return
    fi
    nohup ss-server -c "$USERS_DIR/${username}.json" -f /tmp/ss-server-${username}.pid > /dev/null 2>&1 &
    sleep 1
    local pid=$(cat /tmp/ss-server-${username}.pid 2>/dev/null)
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
        echo -e "${GREEN}✓ 用户 ${username} 已启动 (PID: ${pid})${NC}"
    else
        echo -e "${RED}✗ 启动失败${NC}"
    fi
}

stop_user() {
    echo -ne "${CYAN}输入要停止的用户名: ${NC}"; read -r username
    if [ -f "/tmp/ss-server-${username}.pid" ]; then
        kill $(cat "/tmp/ss-server-${username}.pid") 2>/dev/null && echo -e "${GREEN}✓ 用户 ${username} 已停止${NC}" || echo -e "${RED}✗ 停止失败${NC}"
        rm -f "/tmp/ss-server-${username}.pid"
    else
        echo -e "${RED}✗ 用户 ${username} 未在运行${NC}"
    fi
}

#=============================================================================
# 快捷初始化
#=============================================================================

quick_setup() {
    echo -e "\n${BOLD}══════════ 快捷初始化 ══════════${NC}"
    echo -ne "${CYAN}端口 [默认: 8388]: ${NC}"; read -r port; port=${port:-8388}
    echo -ne "${CYAN}密码 (留空自动生成): ${NC}"; read -r password
    password=${password:-$(tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 16)}
    echo -ne "${CYAN}加密 [1=aes-256-gcm 2=chacha20-ietf-poly1305 默认:1]: ${NC}"
    read -r mc
    case "$mc" in
        2) method="chacha20-ietf-poly1305";;
        *) method="aes-256-gcm";;
    esac

    backup_config
    cat > "$CONFIG_FILE" << EOF
{
    "server": ["0.0.0.0", "::"],
    "mode": "tcp_and_udp",
    "server_port": ${port},
    "password": "${password}",
    "timeout": 86400,
    "method": "${method}",
    "fast_open": true,
    "reuse_port": true
}
EOF
    echo -e "${GREEN}✓ 配置已更新${NC}"
    restart_server
    sleep 1
    show_uri
    echo ""
    show_qr
}

#=============================================================================
# 防火墙管理
#=============================================================================

firewall_menu() {
    local port=$(get_port)
    while true; do
        echo -e "\n${BOLD}══════════ 防火墙管理 ══════════${NC}"
        echo -e "  1) 开放端口 ${port} (UFW)"
        echo -e "  2) 开放端口 ${port} (iptables)"
        echo -e "  3) 查看防火墙状态"
        echo -e "  4) 关闭端口 ${port}"
        echo -e "  0) 返回"
        echo -ne "${CYAN}选择: ${NC}"
        read -r fc
        case "$fc" in
            1)
                ufw allow "$port"/tcp 2>/dev/null && ufw allow "$port"/udp 2>/dev/null
                echo -e "${GREEN}✓ UFW 规则已添加${NC}";;
            2)
                iptables -I INPUT -p tcp --dport "$port" -j ACCEPT 2>/dev/null
                iptables -I INPUT -p udp --dport "$port" -j ACCEPT 2>/dev/null
                echo -e "${GREEN}✓ iptables 规则已添加${NC}"
                echo -e "${YELLOW}提示: 使用 iptables-save 持久化规则${NC}";;
            3)
                echo -e "\n${CYAN}UFW 状态:${NC}"; ufw status 2>/dev/null || echo "UFW 未安装"
                echo -e "\n${CYAN}iptables (端口 ${port}):${NC}"
                iptables -L INPUT -n --line-numbers 2>/dev/null | grep -E "dpt:${port}" || echo "  无相关规则";;
            4)
                ufw delete allow "$port"/tcp 2>/dev/null
                ufw delete allow "$port"/udp 2>/dev/null
                iptables -D INPUT -p tcp --dport "$port" -j ACCEPT 2>/dev/null
                iptables -D INPUT -p udp --dport "$port" -j ACCEPT 2>/dev/null
                echo -e "${GREEN}✓ 端口规则已移除${NC}";;
            0) break;;
            *) echo -e "${RED}无效选择${NC}";;
        esac
    done
}

#=============================================================================
# 一键修复 (解决"能连接但无法代理"的问题)
#=============================================================================

fix_proxy() {
    local port=$(get_port)
    echo -e "\n${BOLD}══════════ 一键修复代理问题 ══════════${NC}\n"

    # 1. 开启 IP 转发
    echo -e "${CYAN}[1/4] 开启 IP 转发...${NC}"
    if [ "$(sysctl -n net.ipv4.ip_forward)" != "1" ]; then
        sysctl -w net.ipv4.ip_forward=1 > /dev/null 2>&1
        echo -e "${GREEN}  ✓ net.ipv4.ip_forward = 1${NC}"
    else
        echo -e "${GREEN}  ✓ IP 转发已开启${NC}"
    fi

    # 2. 开放端口 (INPUT)
    echo -e "${CYAN}[2/4] 开放防火墙端口 ${port}...${NC}"
    if iptables -C INPUT -p tcp --dport "$port" -j ACCEPT >/dev/null 2>&1; then
        echo -e "${GREEN}  ✓ TCP ${port} 规则已存在${NC}"
    else
        iptables -I INPUT -p tcp --dport "$port" -j ACCEPT 2>/dev/null
        echo -e "${GREEN}  ✓ 已添加 TCP ${port} 规则${NC}"
    fi
    if iptables -C INPUT -p udp --dport "$port" -j ACCEPT >/dev/null 2>&1; then
        echo -e "${GREEN}  ✓ UDP ${port} 规则已存在${NC}"
    else
        iptables -I INPUT -p udp --dport "$port" -j ACCEPT 2>/dev/null
        echo -e "${GREEN}  ✓ 已添加 UDP ${port} 规则${NC}"
    fi

    # 3. 允许转发 (FORWARD)
    echo -e "${CYAN}[3/4] 配置转发规则...${NC}"
    if iptables -C FORWARD -p tcp --dport "$port" -j ACCEPT >/dev/null 2>&1; then
        echo -e "${GREEN}  ✓ FORWARD 规则已存在${NC}"
    else
        iptables -I FORWARD -p tcp --dport "$port" -j ACCEPT 2>/dev/null
        iptables -I FORWARD -p udp --dport "$port" -j ACCEPT 2>/dev/null
        echo -e "${GREEN}  ✓ 已添加 FORWARD 规则${NC}"
    fi

    # 4. 持久化
    echo -e "${CYAN}[4/4] 持久化配置...${NC}"
    if ! grep -q "net.ipv4.ip_forward = 1" /etc/sysctl.conf 2>/dev/null; then
        echo "net.ipv4.ip_forward = 1" >> /etc/sysctl.conf 2>/dev/null || echo -e "${YELLOW}  ⚠ 无法写入 /etc/sysctl.conf (只读)${NC}"
    fi
    if command -v iptables-save &>/dev/null; then
        mkdir -p /etc/iptables 2>/dev/null
        iptables-save > /etc/iptables/rules.v4 2>/dev/null || \
        iptables-save > /root/iptables-backup.rules 2>/dev/null
        echo -e "${GREEN}  ✓ 持久化完成${NC}"
    else
        echo -e "${YELLOW}  ⚠ iptables-save 未安装，规则重启后丢失${NC}"
    fi

    echo -e "\n${GREEN}${BOLD}══════════ 修复完成 ══════════${NC}"
    echo -e "${CYAN}如果仍无法代理，请检查:${NC}"
    echo -e "  1. 云服务商安全组是否开放端口 ${port}"
    echo -e "  2. 服务器是否在 NAT 后 (需端口映射)"
    echo -e "  3. 客户端配置是否与服务端一致"
}

#=============================================================================
# 网络诊断
#=============================================================================

speed_test() {
    echo -e "\n${BOLD}══════════ 网络诊断 ══════════${NC}\n"
    local port=$(get_port)
    echo -e "${CYAN}测试端口连通性...${NC}"
    if ss -tuln 2>/dev/null | grep -q ":${port} "; then
        echo -e "${GREEN}✓ 端口 ${port} 已监听${NC}"
    else
        echo -e "${RED}✗ 端口 ${port} 未监听 (可能容器/沙箱隔离)${NC}"
    fi
    echo -e "\n${CYAN}公网 IP:${NC} ${SERVER_IP}"
    echo -e "${CYAN}测试延迟:${NC}"
    ping -c 3 -W 2 8.8.8.8 2>/dev/null | tail -1 || echo -e "${RED}无法连接外网${NC}"
    echo -e "\n${CYAN}IP 转发状态:${NC}"
    sysctl net.ipv4.ip_forward 2>/dev/null
    echo -e "\n${CYAN}INPUT 规则 (端口 ${port}):${NC}"
    iptables -L INPUT -n --line-numbers 2>/dev/null | grep -E "dpt:${port}" || echo -e "${RED}  无${NC}"
    echo -e "\n${CYAN}当前活跃连接:${NC}"
    ss -tnp state established "( sport = :${port} or dport = :${port} )" 2>/dev/null | head -10 || echo "  无"
}

#=============================================================================
# TG (Telegram) 代理管理
#=============================================================================

tg_get_port() { cat "$TG_PORT_FILE" 2>/dev/null || echo "8443"; }
tg_get_secret() { cat "$TG_SECRET_FILE_USER" 2>/dev/null; }

tg_is_running() {
    [ -f "$TG_PID" ] && kill -0 $(cat "$TG_PID") 2>/dev/null
}

tg_start() {
    if [ -f "/usr/local/bin/mtproto-proxy" ]; then
        TG_BIN="/usr/local/bin/mtproto-proxy"
    elif [ ! -f "$TG_BIN" ]; then
        echo -e "${RED}✗ MTProto 代理未安装 (${TG_BIN})${NC}"; return
    fi
    if [ ! -f "$TG_SECRET_FILE" ]; then
        echo -e "${RED}✗ proxy-secret 未下载, 请运行 tg-init${NC}"; return
    fi
    if [ ! -f "$TG_CONF" ]; then
        echo -e "${RED}✗ proxy-multi.conf 未下载, 请运行 tg-init${NC}"; return
    fi
    if tg_is_running; then
        echo -e "${YELLOW}TG 代理已在运行 (PID: $(cat "$TG_PID"))${NC}"; return
    fi
    local port=$(tg_get_port)
    local secret=$(tg_get_secret)
    echo -e "\n${YELLOW}正在启动 TG 代理 (端口: ${port})...${NC}"
    # 先检查端口是否被占用
    if ss -tlnp 2>/dev/null | grep -q ":${port} "; then
        echo -e "${RED}✗ 端口 ${port} 已被占用，请先停止其他进程${NC}"
        ss -tlnp 2>/dev/null | grep ":${port} "
        return
    fi
    # --nat-info 格式: <local-addr>:<global-addr> (使用服务器IP即可)
    nohup "$TG_BIN" -u root -p 8888 -H "$port" -S "$secret" --aes-pwd "$TG_SECRET_FILE" --nat-info "${SERVER_IP}:${SERVER_IP}" --http-stats "$TG_CONF" -M 1 > /tmp/mtproto-proxy.log 2>&1 &
    echo $! > "$TG_PID"
    sleep 3
    if tg_is_running; then
        echo -e "${GREEN}✓ TG 代理启动成功 (PID: $(cat "$TG_PID"))${NC}"
    else
        echo -e "${RED}✗ 启动失败, 日志:${NC}"
        tail -10 /tmp/mtproto-proxy.log 2>/dev/null || echo "无日志"
    fi
}

tg_stop() {
    if ! tg_is_running; then
        echo -e "${YELLOW}TG 代理未在运行${NC}"; return
    fi
    local pid=$(cat "$TG_PID")
    echo -e "${YELLOW}正在停止 TG 代理 (PID: ${pid})...${NC}"
    kill "$pid" 2>/dev/null; sleep 1
    tg_is_running && kill -9 "$pid" 2>/dev/null
    rm -f "$TG_PID"
    echo -e "${GREEN}✓ TG 代理已停止${NC}"
}

tg_restart() { tg_stop 2>/dev/null; sleep 1; tg_start; }

tg_status() {
    local port=$(tg_get_port)
    local secret=$(tg_get_secret)
    echo -e "\n${BOLD}══════════ TG 代理详情 ══════════${NC}"
    echo -e "${CYAN}服务器:${NC} ${YELLOW}${SERVER_IP}${NC}"
    echo -e "${CYAN}端口:  ${NC} ${GREEN}${port}${NC}"
    echo -e "${CYAN}密钥:  ${NC} ${GREEN}${secret}${NC}"
    echo ""
    if tg_is_running; then
        local pid=$(cat "$TG_PID")
        echo -e "${CYAN}状态:${NC} ${GREEN}运行中${NC} (PID: ${pid})"
        echo -e "${CYAN}运行时间:${NC} $(ps -o etime= -p "$pid" 2>/dev/null || echo "未知")"
    else
        echo -e "${CYAN}状态:${NC} ${RED}已停止${NC}"
    fi
    echo -e "\n${CYAN}端口监听:${NC}"
    ss -tuln 2>/dev/null | grep ":${port} " || echo -e "${RED}  未监听${NC}"
}

tg_link() {
    local port=$(tg_get_port)
    local secret=$(tg_get_secret)
    local link="https://t.me/proxy?server=${SERVER_IP}&port=${port}&secret=${secret}"
    echo -e "\n${BOLD}══════════ TG 代理连接链接 ══════════${NC}\n"
    echo -e "${GREEN}${link}${NC}"
    echo ""
    echo -e "${CYAN}手动配置:${NC}"
    echo -e "  服务器: ${GREEN}${SERVER_IP}${NC}"
    echo -e "  端口:   ${GREEN}${port}${NC}"
    echo -e "  密钥:   ${GREEN}${secret}${NC}"
    echo ""
    echo -e "${YELLOW}提示: 复制链接在 Telegram 中打开即可自动配置${NC}"
}

tg_qr() {
    local port=$(tg_get_port)
    local secret=$(tg_get_secret)
    local link="https://t.me/proxy?server=${SERVER_IP}&port=${port}&secret=${secret}"
    echo -e "\n${BOLD}══════════ TG 代理二维码 ══════════${NC}\n"
    if command -v qrencode &>/dev/null; then
        qrencode -t ANSIUTF8 -m 1 -s 2 "$link" 2>/dev/null || {
            qrencode -o /tmp/tg_proxy_qr.png -s 8 "$link" 2>/dev/null
            echo -e "${GREEN}二维码已保存到: /tmp/tg_proxy_qr.png${NC}"
        }
    else
        echo -e "${RED}qrencode 未安装${NC}"
    fi
    echo -e "${YELLOW}提示: 用 Telegram 扫描二维码即可添加代理${NC}"
}

tg_change_port() {
    echo -ne "${CYAN}输入新端口 (1024-65535): ${NC}"; read -r new_port
    [[ "$new_port" =~ ^[0-9]+$ ]] && [ "$new_port" -ge 1024 ] && [ "$new_port" -le 65535 ] || { echo -e "${RED}无效端口${NC}"; return; }
    echo "$new_port" > "$TG_PORT_FILE"
    echo -e "${GREEN}✓ 端口已修改为 ${new_port}${NC}"
    echo -e "${YELLOW}需要重启 TG 代理生效${NC}"
}

tg_new_secret() {
    local new_secret=$(head -c 16 /dev/urandom | xxd -ps)
    echo "$new_secret" > "$TG_SECRET_FILE_USER"
    echo -e "${GREEN}✓ 新密钥已生成${NC}"
    tg_link
    echo -e "${YELLOW}需要重启 TG 代理生效${NC}"
}

tg_add_user() {
    local new_secret=$(head -c 16 /dev/urandom | xxd -ps)
    local port=$(tg_get_port)
    echo -e "${GREEN}✓ 新密钥已生成${NC}"
    echo -e "${CYAN}密钥: ${new_secret}${NC}"
    echo -e "${CYAN}链接: https://t.me/proxy?server=${SERVER_IP}&port=${port}&secret=${new_secret}${NC}"
    echo ""
    echo -e "${YELLOW}提示: 将此密钥添加到启动参数 -S ${new_secret} 即可${NC}"
    echo -e "${YELLOW}当前运行的代理使用密钥: $(tg_get_secret)${NC}"
}

tg_show_logs() {
    local lines=${1:-30}
    echo -e "\n${BOLD}══════════ TG 代理日志 (最近 ${lines} 行) ══════════${NC}\n"
    [ -f /tmp/mtproto-proxy.log ] && tail -n "$lines" /tmp/mtproto-proxy.log || echo -e "${YELLOW}无日志${NC}"
}

tg_stats() {
    echo -e "\n${BOLD}══════════ TG 代理统计 ══════════${NC}\n"
    local stats=$(curl -s --connect-timeout 3 http://127.0.0.1:8888/stats 2>/dev/null)
    if [ -z "$stats" ]; then
        echo -e "${RED}无法获取统计 (代理可能未运行或 --http-stats 未启用)${NC}"; return
    fi
    echo "$stats" | grep -E "total_connections|inbound_connections|outbound_connections|encrypted_connections|forwarded_queries|qps|ready_targets|declared_targets|proxy_mode|proxy_tag_set|http_connections|http_queries|version|workers" | sed 's/^/  /'
}

tg_fix_firewall() {
    local port=$(tg_get_port)
    echo -e "\n${CYAN}开放 TG 代理端口 ${port}...${NC}"
    iptables -C INPUT -p tcp --dport "$port" -j ACCEPT >/dev/null 2>&1 || iptables -I INPUT -p tcp --dport "$port" -j ACCEPT 2>/dev/null
    iptables -C FORWARD -p tcp --dport "$port" -j ACCEPT >/dev/null 2>&1 || iptables -I FORWARD -p tcp --dport "$port" -j ACCEPT 2>/dev/null
    echo -e "${GREEN}✓ 防火墙规则已添加${NC}"
}

tg_fix_all() {
    echo -e "\n${BOLD}${CYAN}══════════ TG 代理一键修复 ══════════${NC}\n"
    # 1. 更新配置文件
    echo -e "${YELLOW}[1/5] 更新 proxy-multi.conf...${NC}"
    curl -s https://core.telegram.org/getProxyConfig -o "$TG_CONF" && echo -e "${GREEN}  ✓ 已更新${NC}" || echo -e "${RED}  ✗ 更新失败${NC}"
    
    # 2. 更新 proxy-secret
    echo -e "${YELLOW}[2/5] 更新 proxy-secret...${NC}"
    curl -s https://core.telegram.org/getProxySecret -o "$TG_SECRET_FILE" && echo -e "${GREEN}  ✓ 已更新${NC}" || echo -e "${RED}  ✗ 更新失败${NC}"
    
    # 3. 防火墙
    echo -e "${YELLOW}[3/5] 配置防火墙...${NC}"
    tg_fix_firewall
    
    # 4. IP 转发
    echo -e "${YELLOW}[4/5] 开启 IP 转发...${NC}"
    sysctl -w net.ipv4.ip_forward=1 > /dev/null 2>&1
    echo -e "${GREEN}  ✓ IP 转发已开启${NC}"
    
    # 5. 重启代理
    echo -e "${YELLOW}[5/5] 重启 TG 代理 (含 NAT 修复)...${NC}"
    tg_restart
    sleep 2
    
    echo -e "\n${GREEN}${BOLD}══════════ 修复完成 ══════════${NC}"
    echo -e "${YELLOW}NAT 信息: ${CYAN}内网 $(ip -4 addr show eth0 2>/dev/null | grep -oP 'inet \K[\d.]+') → 外网 ${SERVER_IP}${NC}"
    tg_link
}

tg_menu() {
    while true; do
        echo -e "\n${BOLD}${CYAN}══════════ TG 代理管理 (MTProto) ══════════${NC}"
        local port=$(tg_get_port)
        if tg_is_running; then
            echo -e "  状态: ${GREEN}● 运行中${NC}  PID: $(cat "$TG_PID")  端口: ${port}"
        else
            echo -e "  状态: ${RED}● 已停止${NC}  端口: ${port}"
        fi
        echo ""
        echo -e "  ${GREEN}1${NC}) 启动 TG 代理      ${GREEN}2${NC}) 停止 TG 代理"
        echo -e "  ${GREEN}3${NC}) 重启 TG 代理      ${GREEN}4${NC}) 查看状态"
        echo -e "  ${GREEN}5${NC}) 显示代理链接      ${GREEN}6${NC}) 生成二维码"
        echo -e "  ${GREEN}7${NC}) 修改端口          ${GREEN}8${NC}) 生成新密钥"
        echo -e "  ${GREEN}9${NC}) 添加新用户        ${GREEN}10${NC}) 查看日志"
        echo -e "  ${GREEN}11${NC}) 开放防火墙        ${GREEN}12${NC}) 重新初始化"
        echo -e "  ${GREEN}13${NC}) ${RED}一键修复${NC}          ${GREEN}14${NC}) 查看统计"
        echo -e "  ${RED}0${NC}) 返回主菜单"
        echo -ne "\n  ${CYAN}选择 [0-14]: ${NC}"
        read -r c
        case "$c" in
            1) tg_start;;
            2) tg_stop;;
            3) tg_restart;;
            4) tg_status;;
            5) tg_link;;
            6) tg_qr;;
            7) tg_change_port;;
            8) tg_new_secret;;
            9) tg_add_user;;
            10) tg_show_logs;;
            11) tg_fix_firewall;;
            12) tg_init;;
            13) tg_fix_all;;
            14) tg_stats;;
            0) break;;
            *) echo -e "${RED}无效选择${NC}";;
        esac
        echo -ne "\n${YELLOW}按 Enter 继续...${NC}"; read -r
    done
}

tg_init() {
    echo -e "\n${BOLD}══════════ TG 代理初始化 ══════════${NC}"
    if [ -f "/usr/local/bin/mtproto-proxy" ]; then
        TG_BIN="/usr/local/bin/mtproto-proxy"
    elif [ ! -f "$TG_BIN" ]; then
        echo -e "${RED}✗ MTProto 代理未编译, 请先安装${NC}"
        echo -e "${YELLOW}手动编译:${NC}"
        echo -e "  cd /tmp && git clone https://github.com/TelegramMessenger/MTProxy.git"
        echo -e "  cd MTProxy && make && cp objs/bin/mtproto-proxy /usr/local/bin/"
        return
    fi
    echo -ne "${CYAN}端口 [默认: 8443]: ${NC}"; read -r port; port=${port:-8443}
    echo ""
    echo -e "${YELLOW}正在下载 Telegram 官方配置文件...${NC}"
    curl -s https://core.telegram.org/getProxySecret -o "$TG_SECRET_FILE" && echo -e "${GREEN}✓ proxy-secret 下载完成${NC}" || echo -e "${RED}✗ 下载失败${NC}"
    curl -s https://core.telegram.org/getProxyConfig -o "$TG_CONF" && echo -e "${GREEN}✓ proxy-multi.conf 下载完成${NC}" || echo -e "${RED}✗ 下载失败${NC}"

    local secret=$(head -c 16 /dev/urandom | xxd -ps)
    echo "$secret" > "$TG_SECRET_FILE_USER"
    echo "$port" > "$TG_PORT_FILE"
    echo -e "${GREEN}✓ 密钥已生成: ${secret}${NC}"

    tg_fix_firewall
    tg_start
    sleep 1
    tg_link
    echo ""
    tg_qr
}

#=============================================================================
# Web 管理器
#=============================================================================
WEB_DIR="/root/web-manager"
WEB_PORT="9090"
WEB_PID_FILE="/tmp/web-manager.pid"

web_is_running() {
    [ -f "$WEB_PID_FILE" ] && kill -0 "$(cat "$WEB_PID_FILE")" 2>/dev/null
}

web_start() {
    if web_is_running; then
        echo -e "${YELLOW}Web 管理器已在运行 (PID: $(cat "$WEB_PID_FILE"))${NC}"
        return
    fi
    echo -e "\n${YELLOW}正在启动 Web 管理器...${NC}"
    cd "$WEB_DIR" && nohup python3 app.py > /tmp/web-manager.log 2>&1 &
    echo $! > "$WEB_PID_FILE"
    sleep 2
    if web_is_running; then
        echo -e "${GREEN}✓ Web 管理器启动成功 (PID: $(cat "$WEB_PID_FILE"))${NC}"
        echo -e "${CYAN}访问地址: http://${SERVER_IP}:${WEB_PORT}${NC}"
    else
        echo -e "${RED}✗ 启动失败${NC}"
        tail -5 /tmp/web-manager.log 2>/dev/null
    fi
}

web_stop() {
    if ! web_is_running; then
        echo -e "${YELLOW}Web 管理器未运行${NC}"; return
    fi
    local pid=$(cat "$WEB_PID_FILE")
    echo -e "\n${YELLOW}正在停止 Web 管理器 (PID: ${pid})...${NC}"
    kill "$pid" 2>/dev/null
    sleep 1
    kill -9 "$pid" 2>/dev/null
    rm -f "$WEB_PID_FILE"
    echo -e "${GREEN}✓ Web 管理器已停止${NC}"
}

web_status() {
    echo -e "\n${BOLD}══════════ Web 管理器状态 ══════════${NC}"
    if web_is_running; then
        echo -e "  状态: ${GREEN}● 运行中${NC}  PID: $(cat "$WEB_PID_FILE")"
        echo -e "  地址: ${CYAN}http://${SERVER_IP}:${WEB_PORT}${NC}"
    else
        echo -e "  状态: ${RED}● 已停止${NC}"
    fi
}

web_menu() {
    while true; do
        echo -e "\n${BOLD}${MAGENTA}══════════ Web 管理面板 ══════════${NC}"
        web_status
        echo ""
        echo -e "  ${GREEN}1${NC}) 启动 Web 管理器"
        echo -e "  ${GREEN}2${NC}) 停止 Web 管理器"
        echo -e "  ${GREEN}3${NC}) 重启 Web 管理器"
        echo -e "  ${GREEN}4${NC}) 查看日志"
        echo -e "  ${RED}0${NC}) 返回主菜单"
        echo -ne "\n  ${CYAN}选择 [0-4]: ${NC}"
        read -r c
        case "$c" in
            1) web_start;;
            2) web_stop;;
            3) web_stop; sleep 1; web_start;;
            4) echo -e "\n${BOLD}══════════ Web 管理器日志 ══════════${NC}\n"; tail -30 /tmp/web-manager.log 2>/dev/null || echo "无日志";;
            0) break;;
            *) echo -e "${RED}无效选择${NC}";;
        esac
        echo -ne "\n${YELLOW}按 Enter 继续...${NC}"; read -r
    done
}

show_dl_info() {
    echo -e "\n${BOLD}${MAGENTA}══════════ 下载加速器 ══════════${NC}"
    echo -e "\n  ${CYAN}使用方法:${NC}"
    echo -e "  ${YELLOW}1.${NC} 浏览器访问: ${GREEN}http://${SERVER_IP}:${WEB_PORT}/dl${NC}"
    echo -e "  ${YELLOW}2.${NC} 粘贴原始下载链接，自动生成加速链接"
    echo -e "  ${YELLOW}3.${NC} 直接使用加速链接:"
    echo -e "     ${GREEN}http://${SERVER_IP}:${WEB_PORT}/dl?url=原始链接${NC}"
    echo ""
    echo -e "  ${CYAN}示例:${NC}"
    echo -e "  原链接: ${YELLOW}https://github.com/user/repo/releases/download/v1.0/file.zip${NC}"
    echo -e "  加速:   ${GREEN}http://${SERVER_IP}:${WEB_PORT}/dl?url=https://github.com/user/repo/releases/download/v1.0/file.zip${NC}"
    echo ""
    echo -e "  ${CYAN}支持:${NC} GitHub Release、GitHub Raw、任意 HTTP/HTTPS 下载链接"
    echo ""
    echo -ne "${YELLOW}按 Enter 返回...${NC}"; read -r
}

show_gh_info() {
    echo -e "\n${BOLD}${MAGENTA}══════════ GitHub 仓库加速器 ══════════${NC}"
    echo -e "\n  ${CYAN}使用方法:${NC}"
    echo -e "  ${YELLOW}1.${NC} 浏览器访问: ${GREEN}http://${SERVER_IP}:${WEB_PORT}/gh${NC}"
    echo -e "  ${YELLOW}2.${NC} 输入 GitHub 仓库地址，自动克隆并展示"
    echo -e "  ${YELLOW}3.${NC} 直接使用加速链接:"
    echo -e "     ${GREEN}http://${SERVER_IP}:${WEB_PORT}/gh?url=仓库地址${NC}"
    echo ""
    echo -e "  ${CYAN}示例:${NC}"
    echo -e "  ${GREEN}http://${SERVER_IP}:${WEB_PORT}/gh?url=https://github.com/Uotan-Dev/UotanToolBox${NC}"
    echo -e "  ${GREEN}http://${SERVER_IP}:${WEB_PORT}/gh?url=https://github.com/Uotan-Dev/UotanToolBox.git${NC}"
    echo ""
    echo -e "  ${CYAN}功能:${NC} 浏览代码、查看 README、下载文件、下载 ZIP"
    echo ""
    echo -ne "${YELLOW}按 Enter 返回...${NC}"; read -r
}

